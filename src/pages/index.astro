---
import Layout from 'layouts/Layout.astro';
import { ContentApp } from '@libs/content';
---

<Layout title="Content" description="Capture & Unfurl URLs"> 
  <main class="relative py-12 px-4 md:py-16">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full blur-3xl opacity-60 mix-blend-multiply" style="background:radial-gradient(circle at 30% 30%, #D6ECFF, transparent 70%)"></div>
      <div class="absolute top-10 right-0 w-[32rem] h-[32rem] rounded-full blur-3xl opacity-60 mix-blend-multiply" style="background:radial-gradient(circle at 70% 30%, #E3D7FF, transparent 70%)"></div>
      <div class="absolute bottom-0 left-1/3 w-[28rem] h-[28rem] rounded-full blur-3xl opacity-50 mix-blend-multiply" style="background:radial-gradient(circle at 50% 50%, #D1F5E1, transparent 70%)"></div>
    </div>
    <div class="relative max-w-5xl mx-auto">
      <header class="mb-10 text-center space-y-4">
        <h1 class="text-4xl md:text-5xl font-semibold bg-gradient-to-r from-brand via-brand-soft to-pastel-mint bg-clip-text text-transparent">Advocate Content Hub</h1>
        <p class="max-w-2xl mx-auto text-base md:text-lg text-ink/70">Capture, unfurl, and curate your developer advocacy content in one focused, lightweight workspace.</p>
      </header>
      <ContentApp client:load />
    </div>
  </main>
</Layout>
